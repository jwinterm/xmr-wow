digraph state_machine {
    rankdir=TB;
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=11, shape=box, style="rounded,filled", fillcolor="#e8f4fd", color="#2980b9"];
    edge [fontname="Helvetica", fontsize=9, color="#555555"];

    label=<<B>XMR-WOW Swap State Machine</B><BR/><FONT POINT-SIZE="10">SwapState enum transitions (crates/xmr-wow-client/src/swap_state.rs)</FONT>>;
    labelloc=t;
    fontsize=16;

    keygen [label=<<B>KeyGeneration</B><BR/>role, params<BR/>my_pubkey, my_proof<BR/>secret_bytes (encrypted)>, fillcolor="#fff9c4"];

    dleq [label=<<B>DleqExchange</B><BR/>+ counterparty_pubkey<BR/>DLEQ proof verified>, fillcolor="#fff9c4"];

    joint [label=<<B>JointAddress</B><BR/>+ addresses (XMR + WOW joint)<BR/>+ before_wow_lock_checkpoint<BR/>swap_id = Hash(K_a || K_b)>, fillcolor="#c8e6c9"];

    wow_locked [label=<<B>WowLocked</B><BR/>+ wow_lock_tx<BR/>+ my_adaptor_pre_sig<BR/>+ counterparty_pre_sig (optional)<BR/>+ before_xmr_lock_checkpoint<BR/>+ refund_artifact (optional)>, fillcolor="#bbdefb"];

    xmr_locked [label=<<B>XmrLocked</B><BR/>+ xmr_lock_tx<BR/>+ my_adaptor_pre_sig<BR/>+ counterparty_pre_sig (optional)<BR/>+ before_xmr_lock_checkpoint<BR/>+ refund_artifact (optional)>, fillcolor="#bbdefb"];

    complete [label=<<B>Complete</B><BR/>role, addresses<BR/>k_b_revealed>, shape=doubleoctagon, fillcolor="#c8e6c9", color="#2e7d32"];

    refunded [label=<<B>Refunded</B><BR/>role, addresses<BR/>refund_tx_hash<BR/>refund_evidence>, shape=doubleoctagon, fillcolor="#ffcdd2", color="#c62828"];

    // Transitions
    keygen -> dleq [label="  receive_counterparty_key()\n  Verify DLEQ proof  "];
    dleq -> joint [label="  derive_joint_addresses()\n  Compute K_joint = K_a + K_b  "];

    // Bob's path: JointAddress -> WowLocked
    joint -> wow_locked [label="  record_wow_lock(tx)\n  Create adaptor pre-sig\n  (Bob only)  ", color="#1565c0", fontcolor="#1565c0"];

    // Alice's path: JointAddress -> XmrLocked (fallback, no WOW verification)
    joint -> xmr_locked [label="  record_xmr_lock(tx)\n  (Alice fallback path)  ", style=dashed, color="#2e7d32", fontcolor="#2e7d32"];

    // Alice verifies WOW then locks XMR
    wow_locked -> xmr_locked [label="  record_xmr_lock(tx)\n  After verifying WOW lock\n  (Alice primary path)  ", color="#2e7d32", fontcolor="#2e7d32"];

    // Receive counterparty pre-sig
    wow_locked -> wow_locked [label="  receive_counterparty_pre_sig()  ", color="#666666", fontcolor="#666666", style=dashed];
    xmr_locked -> xmr_locked [label="  receive_counterparty_pre_sig()  ", color="#666666", fontcolor="#666666", style=dashed];

    // Claim paths
    wow_locked -> complete [label="  complete_with_adaptor_claim()\n  Extract counterparty secret\n  from completed adaptor sig  ", color="#2e7d32", fontcolor="#2e7d32"];
    xmr_locked -> complete [label="  complete_with_adaptor_claim()\n  Extract counterparty secret\n  from completed adaptor sig  ", color="#2e7d32", fontcolor="#2e7d32"];

    // Refund paths
    wow_locked -> refunded [label="  complete_with_refund()\n  After refund height reached  ", color="#c62828", fontcolor="#c62828", style=dashed];
    xmr_locked -> refunded [label="  complete_with_refund()\n  After refund height reached  ", color="#c62828", fontcolor="#c62828", style=dashed];

    // Phase numbers
    subgraph cluster_phases {
        label="Protocol Phases";
        style="dashed"; color="#999999"; fontsize=10;
        node [shape=plaintext, fillcolor=white];
        phases [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6">
            <TR><TD BGCOLOR="#fff9c4"><B>Setup</B></TD><TD>Steps 1-3: Key exchange, DLEQ, joint addresses</TD></TR>
            <TR><TD BGCOLOR="#bbdefb"><B>Lock</B></TD><TD>Steps 4-6: On-chain locks, pre-sig exchange</TD></TR>
            <TR><TD BGCOLOR="#c8e6c9"><B>Claim</B></TD><TD>Steps 7-9: Secret extraction, fund sweeps</TD></TR>
            <TR><TD BGCOLOR="#ffcdd2"><B>Refund</B></TD><TD>After timelock: sweep back to refund address</TD></TR>
        </TABLE>>];
    }
}
